[Unit]
Description=Navidrome Music Server
After=local-fs.target

[Container]
Image=docker.io/deluan/navidrome:latest
AutoUpdate=registry
PublishPort=4533:4533
Volume=/opt/navidrome/data:/data:Z
Volume=/mnt/data/music:/music:ro,Z
Environment=ND_MUSICFOLDER=/music
Environment=ND_DATAFOLDER=/data
Environment=ND_LOGLEVEL=info
Environment=ND_SESSIONTIMEOUT=24h
Environment=ND_BASEURL=
Network=homelab

[Service]
Restart=always

[Install]
WantedBy=default.target
